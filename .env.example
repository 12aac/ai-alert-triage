# Copy this file to ".env" and fill in your real key.
# .env is gitignored so your key never reaches GitHub.
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Model used for Stage 2 classification.
# claude-haiku-4-5 is cheapest/fastest for high-volume triage.
# Swap to claude-sonnet-4-6 if you want stronger reasoning per alert.
TRIAGE_MODEL=claude-haiku-4-5-20251001
